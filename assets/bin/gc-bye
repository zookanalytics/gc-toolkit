#!/usr/bin/env sh
# gc-bye — self-close this agent session.
#
# nohup + & previously worked around the Stop→store.Close ordering race
# in self-close (gc-hybst). The race was eliminated by gascity#12
# (gc-dofiih, 2026-05-20: close bead before stopping runtime). Kept as
# defense-in-depth — the cost is one backgrounded exec, the benefit is
# resilience if the close-before-stop ordering ever regresses.

target="$GC_ALIAS"
if [ -z "$target" ]; then
  echo "gc-bye: GC_ALIAS unset — try \`gc session close <name>\`" >&2
  exit 1
fi
nohup gc session close "$target" >/dev/null 2>&1 &
echo "gc-bye: scheduled close of $target"
